---
import '../styles/global.css';

interface Props {
	title: string;
	contentMaxWidth?: number;
}

const { title, contentMaxWidth } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'News' },
  { href: '/registration', label: 'Registration' },
  { href: '/info', label: 'Tournament Info' },
  { href: '/participants', label: 'Participants' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Double Disc Court European Open 2026" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
		<title>{title} | DDC European Open 2026</title>
	</head>
	<body>
        <header class="nav-header">
            <div class="container nav-container">
                <nav class="nav-links">
                    {navItems.map(item => (
                        <a href={item.href} class={`nav-link ${currentPath === item.href ? 'active' : ''}`}>
                            {item.label}
                        </a>
                    ))}
                </nav>
            </div>
        </header>

        {contentMaxWidth && (
            <a href="/" class="gutter-logo" aria-label="DDC European Open 2026"
               style={`--content-half-width: ${contentMaxWidth / 2}px`}>
                <img src="/DDC.png" alt="DDC European Open 2026" />
            </a>
        )}

		<main>
			<slot />
		</main>

        <footer>
            <div class="container footer-content">
                <p>&copy; 2026 Double Disc Court European Open. Helsinki, Finland.</p>
            </div>
        </footer>
	</body>
</html>
