---
import Layout from '../layouts/Layout.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
---

<Layout title="Registration" contentMaxWidth={640}>
    <div class="container page-content">
        <h1>Registration</h1>

        <div class="card">
            <h2>DDC European Open 2026</h2>
            <p class="lead">Register below to secure your spot. The registration period is between March 31st and May 15th.</p>

            <hr />

            <!--<p class="not-open">Registration is not yet open.</p>-->

            <RegistrationForm />
        </div>
    </div>
</Layout>

<!-- <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script> -->

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
        max-width: 640px;
    }

    .card {
        background: white;
        padding: 3rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
    }

    .lead {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        margin-bottom: 2rem;
    }

    hr {
        border: 0;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
    }

    .not-open {
        font-size: 1.15rem;
        color: var(--color-text-muted);
    }
</style>
