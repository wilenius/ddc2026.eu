---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registration" contentMaxWidth={640}>
    <div class="container page-content">
        <h1>Registration</h1>

        <div class="card">
            <h2>DDC European Open 2026</h2>
            <p class="closed">Registration has been closed.</p>
        </div>
    </div>
</Layout>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
        max-width: 640px;
    }

    .card {
        background: white;
        padding: 3rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
    }

    .closed {
        font-size: 1.15rem;
        color: var(--color-text-muted);
    }
</style>
