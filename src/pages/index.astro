---
import Layout from '../layouts/Layout.astro';
---

<Layout title="News">
	<section class="hero">
		<div class="hero-glow"></div>
		<div class="hero-noise"></div>
		<div class="container hero-content">
			<img src="/DDC.png" alt="DDC European Open 2026" class="hero-logo" />
			<p class="hero-tagline">July 25–26, 2026</p>
			<p class="hero-location">Helsinki, Finland</p>
			<div class="hero-actions">
				<a href="/info" class="btn">Tournament Info</a>
				<a href="/registration" class="btn btn-outline">Register</a>
			</div>
		</div>
	</section>

	<section class="container news-section">
		<h2>Latest News</h2>
		<div class="news-grid">
			<!--
			<article class="news-card">
				<div class="news-date">March 31, 2026</div>
				<h3>Registration now open</h3>
				<p>Welcome to the official website for the DDC European Open 2026. Registration is now open. The registration period is between March 31st and May 15th.</p>
			</article>
			-->
			<article class="news-card">
				<div class="news-date">March 26, 2026</div>
				<h3>The summer is coming</h3>
			    <div class="video-container">
                    <iframe src="https://www.youtube.com/embed/tb7kOKQEyS8"
                        title="DDC European Open 2026"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen>
                    </iframe>
                </div>
			</article>
		</div>
	</section>
</Layout>

<style>
	.hero {
		background: var(--color-black);
		color: white;
		padding: 5rem 0 4rem;
		position: relative;
		overflow: hidden;
		min-height: 80vh;
		display: flex;
		align-items: center;
	}

	.hero-glow {
		position: absolute;
		top: 40%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(255, 107, 0, 0.35) 0%, rgba(255, 184, 0, 0.15) 40%, transparent 70%);
		pointer-events: none;
		animation: pulse-glow 4s ease-in-out infinite alternate;
	}

	.hero-noise {
		position: absolute;
		inset: 0;
		opacity: 0.04;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		background-repeat: repeat;
		background-size: 256px;
		pointer-events: none;
	}

	@keyframes pulse-glow {
		0% { opacity: 0.8; transform: translate(-50%, -50%) scale(1); }
		100% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
	}

	.hero-content {
		text-align: center;
		position: relative;
		z-index: 1;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-logo {
		width: 320px;
		height: 320px;
		object-fit: contain;
		filter: brightness(0) invert(1);
		margin-bottom: 2rem;
		animation: logo-enter 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
		drop-shadow: 0 0 60px rgba(255, 107, 0, 0.4);
	}

	@keyframes logo-enter {
		0% { opacity: 0; transform: scale(0.85); }
		100% { opacity: 1; transform: scale(1); }
	}

	.hero-tagline {
		font-family: var(--font-heading);
		font-size: 2.2rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-orange);
		margin-bottom: 0.25rem;
		animation: fade-up 0.6s 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	.hero-location {
		font-family: var(--font-body);
		font-size: 1.15rem;
		color: rgba(255, 255, 255, 0.6);
		font-weight: 400;
		margin-bottom: 2.5rem;
		letter-spacing: 0.04em;
		animation: fade-up 0.6s 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	@keyframes fade-up {
		0% { opacity: 0; transform: translateY(16px); }
		100% { opacity: 1; transform: translateY(0); }
	}

	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
		animation: fade-up 0.6s 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	.hero-actions .btn-outline {
		border-color: rgba(255, 255, 255, 0.3);
		color: white;
	}

	.hero-actions .btn-outline:hover {
		border-color: var(--color-orange);
		background-color: var(--color-orange);
		color: white;
	}

	.news-section {
		padding: 2.5rem 0 5rem;
	}

	.news-section h2 {
		font-size: 2.5rem;
		position: relative;
		display: inline-block;
	}

	.news-section h2::after {
		content: '';
		display: block;
		width: 60px;
		height: 4px;
		background: var(--color-orange);
		margin-top: 0.5rem;
	}

	.news-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
		margin-top: 2.5rem;
	}

	.news-card {
		background: white;
		padding: 2rem;
		border-radius: 2px;
		box-shadow: var(--shadow-md);
		transition: transform 0.2s, box-shadow 0.2s;
		border-left: 4px solid var(--color-orange);
	}

	.news-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.news-date {
		color: var(--color-orange);
		font-weight: 700;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.5rem;
	}

	.news-card h3 {
		font-size: 1.5rem;
		margin-bottom: 0.75rem;
	}

	.news-card p {
		color: var(--color-text-muted);
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.hero {
			min-height: 60vh;
			padding: 3rem 0;
		}
		.hero-logo {
			width: 220px;
			height: 220px;
		}
		.hero-tagline {
			font-size: 1.5rem;
		}
	}
</style>
