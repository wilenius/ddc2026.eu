---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Participants Info" contentMaxWidth={900}>
    <div class="container page-content">
        <h1>Info for Participants</h1>
        
        <div class="content-wrapper">
            <section>
                <h2>List of confirmed players</h2>
                <div id="participants-list">
                    <p class="loading">Loading participants…</p>
                </div>
            </section>

            <section>
                <h2>Venue & logistics</h2>
                <p>The tournament will be held at the Tali Sports Park (Talin liikuntapuisto) in Helsinki.</p>
                <iframe
                    src="https://www.openstreetmap.org/export/embed.html?bbox=24.8660300,60.2114270,24.8740550,60.2141560&layer=mapnik&marker=60.2128,24.8700"
                    class="venue-map"
                    loading="lazy"
                    title="Tali Sports Park map"
                ></iframe>
            </section>

            <section>
                <h2>Accommodation</h2>
                <p>Information about recommended hotels and hostels will be posted here soon.</p>
            </section>

            <section>
                <h2>Travel</h2>
                <p>We recommend using public transportation to reach the tournament venue. Here's a <a href="https://reittiopas.hsl.fi/reitti/-/Purotie%208%2C%20it%C3%A4inen%2C%20Helsinki%3A%3A60.215522%2C24.868068?arriveBy=false&locale=en&time=1774604769.525" target="_blank" rel="noopener">pre-filled journey planner link</a> for checking travel times.</p>
            </section>
        </div>
    </div>
</Layout>

<script>
  const WORKER_URL = "https://ddc2026-registration.heikki-wilenius.workers.dev";
  const container = document.getElementById("participants-list")!;

  async function loadParticipants() {
    try {
      const res = await fetch(`${WORKER_URL}/participants`);
      const participants: { name: string }[] = await res.json();

      if (participants.length === 0) {
        container.innerHTML = "<p>No confirmed participants yet.</p>";
        return;
      }

      const ol = document.createElement("ol");
      ol.className = "participant-list";
      for (const p of participants) {
        const li = document.createElement("li");
        li.textContent = p.name;
        if (p.name === "Anonymous") li.classList.add("anonymous");
        ol.appendChild(li);
      }
      container.replaceChildren(ol);
    } catch {
      container.innerHTML = "<p>Could not load participants. Please try again later.</p>";
    }
  }

  loadParticipants();
</script>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
        max-width: 900px;
    }
    
    section {
        margin-bottom: 4rem;
        background: white;
        padding: 2.5rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
    }

    h2 {
        color: var(--color-black);
        font-size: 1.75rem;
    }
    
    .venue-map {
        width: 100%;
        height: 300px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        margin-top: 1.5rem;
    }

    .participant-list {
        padding-left: 1.5rem;
        margin: 0;
    }

    .participant-list li {
        padding: 0.35rem 0;
        font-size: 1rem;
    }

    .participant-list li.anonymous {
        color: var(--color-text-muted);
        font-style: italic;
    }

    .loading {
        color: var(--color-text-muted);
    }
</style>
