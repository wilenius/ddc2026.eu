---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Participants Info" contentMaxWidth={900}>
    <div class="container page-content">
        <h1>Info for Participants</h1>
        
        <div class="content-wrapper">
            <section>
                <h2>List of registered players</h2>
                <div id="participants-list">
                    <p class="loading">Loading participants…</p>
                </div>
                <div class="participants-note">
                    <p>Don't see your name on the list even though you signed up? You need to confirm your participation by clicking the link in the confirmation email. Check your spam folder if you don't find it.</p>
                </div>
            </section>

            <section>
                <h2>Venue & logistics</h2>
                <p>The tournament will be held at the Tali Sports Park (Talin liikuntapuisto) in Helsinki.</p>
                <iframe
                    src="https://www.openstreetmap.org/export/embed.html?bbox=24.8660300,60.2114270,24.8740550,60.2141560&layer=mapnik&marker=60.2128,24.8700"
                    class="venue-map"
                    loading="lazy"
                    title="Tali Sports Park map"
                ></iframe>
            </section>

            <section>
                <h2>Accommodation</h2>
                <p>We have partnered with two accommodation providers to offer discounted stays for tournament participants. Discount codes are in your registration confirmation email.</p>
                <ul class="accommodation-list">
                    <li><strong><a href="https://www.forenom.com" target="_blank" rel="noopener">Forenom</a></strong> — 10% discount for all Forenom Hostels and Aparthotels in the greater Helsinki area, July 24–27. The <a href="https://www.forenom.com/fi/hostellit/helsinki/forenom-hostel-helsinki-pitajanmaki/145/" target="_blank" rel="noopener">nearest one</a> is a five-minute walk from the tournament venue.</li>
                    <li><strong><a href="https://www.cheapsleep.fi/" target="_blank" rel="noopener">CheapSleep Helsinki</a></strong> — 20% discount on dormitory and private rooms, July 22–30. A more central option, about 40 minutes by public transport to the venue.</li>
                </ul>
            </section>

            <section>
                <h2>Travel</h2>
                <p>We recommend using public transportation to reach the tournament venue. Here's a <a href="https://reittiopas.hsl.fi/reitti/-/Purotie%208%2C%20it%C3%A4inen%2C%20Helsinki%3A%3A60.215522%2C24.868068?arriveBy=false&locale=en" target="_blank" rel="noopener">pre-filled journey planner link</a> for checking travel times.</p>
            </section>
        </div>
    </div>
</Layout>

<script>
  const WORKER_URL = "https://ddc2026-registration.heikki-wilenius.workers.dev";
  const container = document.getElementById("participants-list")!;

  async function loadParticipants() {
    try {
      const res = await fetch(`${WORKER_URL}/participants`);
      const participants: { name: string; division: string }[] = await res.json();

      if (participants.length === 0) {
        container.innerHTML = "<p>No confirmed participants yet.</p>";
        return;
      }

      const divisionLabels: Record<string, string> = {
        open: "Open",
        women: "Women",
        junior: "Junior",
      };

      const ol = document.createElement("ol");
      ol.className = "participant-list";
      for (const p of participants) {
        const li = document.createElement("li");
        if (p.name === "Anonymous") li.classList.add("anonymous");
        const nameSpan = document.createElement("span");
        nameSpan.textContent = p.name;
        li.appendChild(nameSpan);
        const divSpan = document.createElement("span");
        divSpan.className = "division-badge";
        divSpan.textContent = divisionLabels[p.division] || "Open";
        li.appendChild(divSpan);
        ol.appendChild(li);
      }
      container.replaceChildren(ol);
    } catch {
      container.innerHTML = "<p>Could not load participants. Please try again later.</p>";
    }
  }

  loadParticipants();
</script>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
        max-width: 900px;
    }
    
    section {
        margin-bottom: 4rem;
        background: white;
        padding: 2.5rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
    }

    h2 {
        color: var(--color-black);
        font-size: 1.75rem;
    }
    
    .venue-map {
        width: 100%;
        height: 300px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        margin-top: 1.5rem;
    }

    #participants-list :global(.participant-list) {
        list-style: none;
        padding: 0;
        margin: 0;
        counter-reset: participant;
    }

    #participants-list :global(.participant-list li) {
        padding: 0.35rem 0;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        counter-increment: participant;
    }

    #participants-list :global(.participant-list li::before) {
        content: counter(participant) ".";
        min-width: 1.75rem;
        flex-shrink: 0;
        color: var(--color-text-muted);
    }

    #participants-list :global(.participant-list li > span:first-of-type) {
        flex: 1;
    }

    #participants-list :global(.participant-list li.anonymous > span:first-of-type) {
        color: var(--color-text-muted);
        font-style: italic;
    }

    #participants-list :global(.division-badge) {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: #f5f0eb;
        color: var(--color-text-muted);
        padding: 0.1rem 0.5rem;
        border-radius: 3px;
    }

    .participants-note {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #faf5f0;
        border: 1px solid var(--color-border);
        border-radius: 4px;
    }

    .participants-note p {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .accommodation-list {
        list-style: none;
        padding: 0;
        margin: 1.25rem 0 0;
    }

    .accommodation-list li {
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        background: #faf5f0;
        border-left: 3px solid var(--color-orange);
        border-radius: 2px;
        line-height: 1.6;
    }

    .accommodation-list li:last-child {
        margin-bottom: 0;
    }

    .loading {
        color: var(--color-text-muted);
    }
</style>
