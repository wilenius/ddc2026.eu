---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Spectator Info" contentMaxWidth={900}>
    <div class="container page-content">
        <h1>Info for Spectators</h1>
        <div class="content-wrapper">

            <section class="fi-box">
                <h2>Ohjeita katsojille</h2>
                <p>
                    Tervetuloa seuraamaan tuplakiekon (Double Disc Court) European
                    Open -turnausta Talin liikuntapuistoon (Purotie 8) 25.–26.7.2026.
                    Kenttien 1 ja 2 vieressä on katsomot. Paras aika saapua paikalle
                    on sunnuntaina klo 12.15 alkaen, jolloin pelataan välierät ja
                    sijoitusottelut &ndash; välierät pelataan katsomoiden vieressä
                    kentillä 1 ja 2. Vapaa pääsy!
                </p>
            </section>

            <section>
                <h2>When to come</h2>
                <p>
                    Spectators are very welcome, and entry is free. The
                    <strong>best time to come is Sunday 26th July from 12:15
                    onwards</strong>, when the semi-finals and placement matches are
                    played. The semi-finals take place on <strong>courts 1 and 2,
                    right next to the stands</strong>.
                </p>
                <table>
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Sunday highlights</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>12:15</td>
                            <td>Semi-finals and placement matches</td>
                        </tr>
                        <tr>
                            <td>13:30</td>
                            <td>Third-place playoff</td>
                        </tr>
                        <tr>
                            <td>14:15</td>
                            <td>Final</td>
                        </tr>
                        <tr>
                            <td>~16:00</td>
                            <td>Medal ceremony</td>
                        </tr>
                    </tbody>
                </table>
                <p>
                    There is play throughout the weekend: pool games run on Saturday
                    from 09:45 to 16:00 and on Sunday morning from 09:45 onwards.
                </p>
            </section>

            <section>
                <h2>Where to watch</h2>
                <p>
                    There are stands next to <strong>courts 1 and 2</strong> — this
                    is where the semi-finals will be played, so the best matches
                    happen right in front of you.
                </p>
            </section>

            <section>
                <h2>Getting there</h2>
                <figure>
                    <img src="/tali_spectators.png" alt="Venue map showing the entrance gate, the walking route to the courts, and the stands" />
                    <figcaption aria-hidden="true">The entrance gate, the route to the courts, and the stands</figcaption>
                </figure>
                <p>
                    The tournament courts are located in the Tali Sports Park. See
                    the map above for entrance instructions.
                </p>
                <p>The address is: Purotie 8, 00380 Helsinki, Finland</p>
                <ul>
                    <li><a href="https://www.google.com/maps/search/?api=1&amp;query=60.2128,24.8700">Google Maps</a></li>
                    <li><a href="https://www.openstreetmap.org/?mlat=60.2128&amp;mlon=24.8700#map=17/60.2128/24.8700">OpenStreetMap</a></li>
                </ul>
                <p>
                    We recommend using public transport (HSL) — the venue is in zone
                    AB. If you arrive by car, there is a spacious parking lot right
                    next to the venue (paid via the ParkMan app). More travel details
                    are on the <a href="/participants">participants info page</a>.
                </p>
            </section>

            <section>
                <h2>Can't make it?</h2>
                <p>
                    Matches will be streamed by Studio Allround:
                    <a href="https://www.youtube.com/@studioallround/live">www.youtube.com/@studioallround/live</a>
                </p>
            </section>

        </div>

        <section class="organisers-section">
            <h2>Organisers</h2>
            <div class="organisers-logos">
                <a href="https://www.tuplakiekko.fi" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/HKI_DDC.png" alt="Helsinki DDC" />
                </a>
                <a href="https://ultimate.fi/liitto/" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/slkl.png" alt="SLKL" />
                </a>
            </div>

            <h2>Partners</h2>
            <div class="organisers-logos">
                <a href="https://www.hel.fi" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/helsinki.png" alt="City of Helsinki" />
                </a>
                <a href="https://www.forenom.com" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/forenom.png" alt="Forenom" />
                </a>
                <a href="https://www.cheapsleep.fi/" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/cheapsleep.png" alt="CheapSleep Helsinki" />
                </a>
            </div>

            <p class="contact-email">
                Questions? Contact us at <a href="mailto:info@ddc2026.eu">info@ddc2026.eu</a>
            </p>
        </section>
    </div>
</Layout>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
        max-width: 900px;
        margin: 0 auto;
    }

    .content-wrapper > section {
        background: #fff;
        padding: 2.5rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
        margin-bottom: 3rem;
    }

    .content-wrapper > section:last-child {
        margin-bottom: 0;
    }

    section > h2 {
        font-size: 1.9rem;
        margin-bottom: 1rem;
        display: inline-block;
    }

    section > h2::after {
        content: "";
        display: block;
        width: 60px;
        height: 4px;
        background: var(--color-orange);
        margin-top: 0.5rem;
    }

    /* Finnish callout box on top — black card, like the site's blockquotes. */
    .content-wrapper > section.fi-box {
        background: var(--color-black);
        color: #fff;
    }

    .fi-box > h2 {
        color: var(--color-orange);
    }

    .fi-box p {
        color: #fff;
        margin-bottom: 0;
    }

    p {
        margin-bottom: 1rem;
    }

    ul {
        margin: 0.5rem 0 1rem 1.5rem;
    }

    li {
        margin-bottom: 0.4rem;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 1.5rem;
        font-size: 0.95rem;
    }

    thead th {
        background: var(--color-black);
        color: #fff;
        font-family: var(--font-heading);
        font-weight: 400;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-align: left;
        padding: 0.55rem 0.75rem;
    }

    tbody td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid var(--color-border);
        vertical-align: top;
    }

    tbody tr:nth-child(even) {
        background: var(--color-cream);
    }

    figure {
        margin: 1.5rem 0;
    }

    figure img {
        width: 100%;
        border: 1px solid var(--color-border);
        border-radius: 8px;
    }

    figcaption {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        font-style: italic;
        margin-top: 0.5rem;
    }

    .organisers-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 2px solid var(--color-border);
        text-align: center;
    }

    .organisers-section > h2 {
        font-size: 1.9rem;
    }

    .organisers-logos {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 3rem;
        margin: 2rem 0;
    }

    .organiser-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.85;
        transition: opacity 0.2s;
    }

    .organiser-logo:hover {
        opacity: 1;
    }

    .organiser-logo img {
        height: 80px;
        width: auto;
        object-fit: contain;
    }

    .contact-email {
        margin-top: 1.5rem;
        font-size: 1rem;
        color: var(--color-text-muted);
    }

    .contact-email a {
        color: var(--color-orange);
        font-weight: 600;
        transition: color 0.2s;
    }

    .contact-email a:hover {
        color: var(--color-orange-deep);
    }
</style>
