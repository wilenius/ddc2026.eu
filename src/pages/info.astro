---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tournament Info">
    <div class="container page-content">
        <h1>Tournament Information</h1>
        
        <div class="info-grid">
            <section class="info-section">
                <h2>Dates & Location</h2>
                <div class="info-card">
                    <div class="icon-text">
                        <span class="label">When</span>
                        <span class="value">July 25–26, 2026</span>
                    </div>
                    <div class="icon-text">
                        <span class="label">Where</span>
                        <span class="value">Tali Sports Park<br>Helsinki, Finland</span>
                    </div>
                </div>
            </section>
            
            <section class="info-section">
                <h2>Schedule</h2>
                <div class="schedule-card">
                    <h3>Friday, July 24th</h3>
                    <ul>
                        <li><span class="time">Evening</span> <strong>Get-together & Pickup Games</strong><br>Join us for casual games and meet the other players.</li>
                    </ul>
                    
                    <h3>Saturday, July 25th</h3>
                    <ul>
                        <li><span class="time">TBA</span> <strong>Tournament Day 1</strong></li>
                    </ul>

                    <h3>Sunday, July 26th</h3>
                    <ul>
                        <li><span class="time">TBA</span> <strong>Tournament Day 2 & Finals</strong></li>
                    </ul>
                </div>
            </section>
        </div>
    </div>
</Layout>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-top: 2rem;
    }
    
    @media (min-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
    
    .info-card, .schedule-card {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--color-border);
        height: 100%;
    }
    
    .icon-text {
        margin-bottom: 1.5rem;
    }
    
    .icon-text:last-child {
        margin-bottom: 0;
    }
    
    .label {
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--color-brand-teal);
        margin-bottom: 0.25rem;
    }
    
    .value {
        font-size: 1.25rem;
        font-weight: 500;
    }
    
    .schedule-card h3 {
        color: var(--color-brand-blue);
        border-bottom: 2px solid rgba(0,0,0,0.05);
        padding-bottom: 0.5rem;
        margin-top: 1.5rem;
    }
    
    .schedule-card h3:first-child {
        margin-top: 0;
    }
    
    ul {
        list-style: none;
        padding: 0;
        margin-top: 1rem;
    }
    
    li {
        margin-bottom: 1rem;
        padding-left: 1rem;
        border-left: 3px solid var(--color-accent);
    }
    
    .time {
        display: inline-block;
        background: var(--color-bg);
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-right: 0.5rem;
        color: var(--color-text-muted);
    }
</style>
