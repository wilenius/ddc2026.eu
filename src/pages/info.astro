---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tournament Info" contentMaxWidth={1200}>
    <div class="container page-content">
        <h1>Tournament Information</h1>
        
        <div class="info-grid">
            <section class="info-section">
                <h2>Dates & Location</h2>
                <div class="info-card">
                    <div class="icon-text">
                        <span class="label">When</span>
                        <span class="value">July 25–26, 2026</span>
                    </div>
                    <div class="icon-text">
                        <span class="label">Where</span>
                        <span class="value">Tali Sports Park<br>Helsinki, Finland</span>
                    </div>
                </div>
            </section>
            
            <section class="info-section">
                <h2>Schedule</h2>
                <div class="schedule-card">
                    <h3>Friday, July 24th</h3>
                    <ul>
                        <li><span class="time">Evening</span> <strong>Get-together & Pickup Games</strong><br>Join us for casual games and meet the other players.</li>
                    </ul>
                    
                    <h3>Saturday, July 25th</h3>
                    <ul>
                        <li><span class="time">TBA</span> <strong>Tournament Day 1</strong></li>
                    </ul>

                    <h3>Sunday, July 26th</h3>
                    <ul>
                        <li><span class="time">TBA</span> <strong>Tournament Day 2 & Finals</strong></li>
                    </ul>
                </div>
            </section>
        </div>

        <section class="organisers-section">
            <h2>Organisers</h2>
            <div class="organisers-logos">
                <a href="https://www.tuplakiekko.fi" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/HKI_DDC.png" alt="Helsinki DDC" />
                </a>
                <a href="https://ultimate.fi/liitto/" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/slkl.png" alt="SLKL" />
                </a>
                <a href="https://www.hel.fi" target="_blank" rel="noopener" class="organiser-logo">
                    <img src="/helsinki.png" alt="City of Helsinki" />
                </a>
            </div>
            <p class="contact-email">
                Questions? Contact us at <a href="mailto:info@ddc2026.eu">info@ddc2026.eu</a>
            </p>
        </section>
    </div>
</Layout>

<style>
    .page-content {
        padding: 4rem var(--spacing-md);
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-top: 2rem;
    }
    
    @media (min-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
    
    .info-card, .schedule-card {
        background: white;
        padding: 2rem;
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--color-orange);
        height: 100%;
    }
    
    .icon-text {
        margin-bottom: 1.5rem;
    }
    
    .icon-text:last-child {
        margin-bottom: 0;
    }
    
    .label {
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--color-orange);
        margin-bottom: 0.25rem;
    }
    
    .value {
        font-size: 1.25rem;
        font-weight: 500;
    }
    
    .schedule-card h3 {
        color: var(--color-black);
        border-bottom: 2px solid rgba(0,0,0,0.05);
        padding-bottom: 0.5rem;
        margin-top: 1.5rem;
    }
    
    .schedule-card h3:first-child {
        margin-top: 0;
    }
    
    ul {
        list-style: none;
        padding: 0;
        margin-top: 1rem;
    }
    
    li {
        margin-bottom: 1rem;
        padding-left: 1rem;
        border-left: 3px solid var(--color-yellow);
    }
    
    .time {
        display: inline-block;
        background: var(--color-bg);
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-right: 0.5rem;
        color: var(--color-text-muted);
    }

    .organisers-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 2px solid var(--color-border);
        text-align: center;
    }

    .organisers-logos {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 3rem;
        margin: 2rem 0;
    }

    .organiser-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.85;
        transition: opacity 0.2s;
    }

    .organiser-logo:hover {
        opacity: 1;
    }

    .organiser-logo img {
        height: 80px;
        width: auto;
        object-fit: contain;
    }

    .contact-email {
        margin-top: 1.5rem;
        font-size: 1rem;
        color: var(--color-text-muted);
    }

    .contact-email a {
        color: var(--color-orange);
        font-weight: 600;
        transition: color 0.2s;
    }

    .contact-email a:hover {
        color: var(--color-orange-deep);
    }
</style>
